{
  "swagger": "3.0.4",
  "info": {
    "title": "web-scraping.dev by Scrapfly",
    "version": "1.0.27"
  },
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/products": {
      "get": {
        "summary": "Product Paging Get",
        "description": "Product pagination by page number through a get parameter. Valid pages are 1-6",
        "operationId": "product_paging_get_api_products_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "The page number to return, max 5",
            "type": "integer",
            "exclusiveMaximum": 6,
            "exclusiveMinimum": 0,
            "default": 1
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "description": "Sort order. This is useful for getting around paging limit of 25 products (total is 28)",
            "enum": [
              "asc",
              "desc"
            ],
            "type": "string",
            "default": "asc"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "anyOf": [
              {
                "enum": [
                  "apparel",
                  "consumables",
                  "household"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/PagingPage"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      },
      "post": {
        "summary": "Product Paging Post",
        "description": "Product pagination by page number submitted through a JSON POST. Valid pages are 1-6",
        "operationId": "product_paging_post_api_products_post",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PagePaging"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/PagingPage"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/product": {
      "get": {
        "summary": "Product Get",
        "description": "returns product data for given numeric id. Available ids are: 1 to 28",
        "operationId": "product_get_api_product_get",
        "parameters": [
          {
            "name": "product_id",
            "in": "query",
            "required": true,
            "description": "The id of the product you want to get reviews for",
            "example": 1,
            "type": "integer",
            "exclusiveMaximum": 29,
            "exclusiveMinimum": 0
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/Product"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      },
      "post": {
        "summary": "Product Post",
        "description": "returns product data for given numeric id through JSON post. Available ids are: 1 to 28\nThis endpoint also supports multi product return if product `id` is a list of ids like `[1,2,3]`",
        "operationId": "product_post_api_product_post",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ProductQuery"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/definitions/Product"
                },
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/Product"
                  }
                }
              ],
              "title": "Response Product Post Api Product Post"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/reviews": {
      "get": {
        "summary": "Review Paging Get",
        "description": "Review pagination by page number through a get parameter\n\nThe review paging endpoint is protected by a CSRF header requirement.\nThe expected values are:\n```\n{\n    \"X-Csrf-Token\": \"secret-csrf-token-123\",\n}\n```\n\nNote that /docs API player cannot override the Referer header the browser is sending\nso this endpoint will not work in the API player.",
        "operationId": "review_paging_get_api_reviews_get",
        "parameters": [
          {
            "name": "product_id",
            "in": "query",
            "required": true,
            "description": "The id of the product you want to get reviews for",
            "example": 1,
            "type": "integer",
            "exclusiveMaximum": 29,
            "exclusiveMinimum": 0
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "The page number to return, there's no paging limit for reviews",
            "type": "integer",
            "default": 1
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "enum": [
              "asc",
              "desc"
            ],
            "type": "string",
            "default": "asc"
          },
          {
            "name": "x-csrf-token",
            "in": "header",
            "required": true,
            "description": "cross site forgery token. It's static in web-scraping.dev",
            "example": "secret-csrf-token-123",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/PagingPage"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/review": {
      "get": {
        "summary": "Review Get",
        "description": "returns product's review data. Requires product id and available ids are: 1 to 28",
        "operationId": "review_get_api_review_get",
        "parameters": [
          {
            "name": "product_id",
            "in": "query",
            "required": true,
            "description": "The id of the product you want to get reviews for",
            "example": 1,
            "type": "integer",
            "exclusiveMaximum": 29,
            "exclusiveMinimum": 0
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Review"
              },
              "title": "Response Review Get Api Review Get"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/testimonials": {
      "get": {
        "summary": "Testimonial Paging Html",
        "description": "Testimonial pagination by page number through a get parameter. Returns rendered page HTML.\n\nThe testimonial paging endpoint is protected by a referer header requirement.\nThe expected values are:\n```\n{\n    \"Referer\": \"https://web-scraping.dev/testimonials\",\n}\n```",
        "operationId": "testimonial_paging_html_api_testimonials_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "default": 1
          },
          {
            "name": "referer",
            "in": "header",
            "required": true,
            "description": "Referer header to validate",
            "example": "https://web-scraping.dev/",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "type": "string"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/download-file": {
      "post": {
        "summary": "Download File Post",
        "description": "Returns a PDF file with Content-Disposition header set to attachment.\nThis simulates a form submission that triggers a file download in a new tab.\nThe file returned is a sample PDF document.",
        "operationId": "download_file_post_api_download_file_post",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/api/ai-content-obfuscation": {
      "get": {
        "summary": "Ai Content Obfuscation",
        "description": "Returns text with hidden Unicode characters designed to confuse AI/LLM scrapers.\n\nThis endpoint demonstrates a common anti-AI scraping technique where content\nis obfuscated using invisible Unicode characters (zero-width spaces,\ninvisible separators, etc.) mixed with visible content.\n\nThe challenge is to extract only the visible cipher from the obfuscated text.\nAI models often struggle with these invisible characters during text processing.",
        "operationId": "ai_content_obfuscation_api_ai_content_obfuscation_get",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "type": "string"
            }
          }
        }
      }
    },
    "/api/login": {
      "post": {
        "summary": "Login Post",
        "description": "Mocks formdata based login. If correct username and password is provided response with\n`Set-Cookie` header of value `auth=user123-secret-token` will be returned which will grant access\nto [/auth/login](/auth/login) html page.\n\nCredentials:\n    username=user123\n    password=password",
        "operationId": "login_post_api_login_post",
        "parameters": [
          {
            "name": "referer",
            "in": "header",
            "required": false,
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          {
            "name": "username",
            "in": "formData",
            "required": true,
            "type": "string"
          },
          {
            "name": "password",
            "in": "formData",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/logout": {
      "get": {
        "summary": "Logout Get",
