    "/password-manager-test/passkey/register/begin": {
      "post": {
        "summary": "Password Manager Test Passkey Register Begin",
        "description": "Hand the page a fresh challenge + user info for\nnavigator.credentials.create(). This is the *registration* flow \u2014\na click on this triggers Chrome / the active passkey provider\n(1Password extension, Touch ID, etc.) to offer \"save this passkey\".\n\nThe server doesn't persist anything beyond a short-lived challenge\ncookie used by /register/complete to verify the round-trip.",
        "operationId": "password_manager_test_passkey_register_begin_password_manager_test_passkey_register_begin_post",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/password-manager-test/passkey/register/complete": {
      "post": {
        "summary": "Password Manager Test Passkey Register Complete",
        "description": "Acknowledge the registration. The server doesn't actually persist\nthe public key in this fixture \u2014 that's not what we're testing. We\njust confirm the page received a credentialId and the challenge\nround-tripped, then let the page show success. The real proof is\nthat *some* authenticator (1Password, Touch ID, the virtual\nauthenticator under CDP) actually performed the attestation\nceremony \u2014 which it only does if it was offered the save prompt\nand accepted it.",
        "operationId": "password_manager_test_passkey_register_complete_password_manager_test_passkey_register_complete_post",
        "parameters": [
          {
            "name": "pm_test_register_challenge",
            "in": "cookie",
            "required": false,
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          {
            "name": "challenge",
            "in": "formData",
            "required": true,
            "type": "string"
          },
          {
            "name": "credential_id",
            "in": "formData",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/password-manager-test/passkey/begin": {
      "post": {
        "summary": "Password Manager Test Passkey Begin",
        "description": "Hand the page a fresh challenge for navigator.credentials.get().\n\nThe challenge is also stored in a short-lived cookie so the /complete\nendpoint can verify the assertion was signed over the same value.",
        "operationId": "password_manager_test_passkey_begin_password_manager_test_passkey_begin_post",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/password-manager-test/passkey/complete": {
      "post": {
        "summary": "Password Manager Test Passkey Complete",
        "description": "Best-effort verification that the page returned an assertion matching\nour hardcoded credential. We do NOT verify the signature here \u2014 the goal\nis to drive the CDP flow, not reimplement WebAuthn server validation.\n\nReal RPs would verify clientDataJSON, authenticatorData, and signature\nagainst the stored public key. For the test fixture we only check the\ncredentialId matches the hardcoded value and the challenge round-trips.",
        "operationId": "password_manager_test_passkey_complete_password_manager_test_passkey_complete_post",
        "parameters": [
          {
            "name": "pm_test_challenge",
            "in": "cookie",
            "required": false,
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          {
            "name": "challenge",
            "in": "formData",
            "required": true,
            "type": "string"
          },
          {
            "name": "credential_id",
            "in": "formData",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/password-manager-test/credential.json": {
      "get": {
        "summary": "Password Manager Test Credential Export",
        "description": "Hand back the hardcoded test credential as JSON.\n\nTests fetch this and feed it into the WebAuthn virtual authenticator\nvia PasswordManager.providePasskey (or the underlying WebAuthn CDP\ndomain). The credential is intentionally weak and public \u2014 it exists\nonly for end-to-end testing.",
        "operationId": "password_manager_test_credential_export_password_manager_test_credential_json_get",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful Response"
          }
        }
      }
    }
  },
